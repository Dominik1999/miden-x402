#! AgentDebitNote — pre-funded note for x402 agent payments.
#!
#! Consume path (before expiry): requires BOTH agent_sig AND facilitator_sig
#! over the same debit message. Creates P2ID to merchant + remainder note.
#! Both prepared signatures must be on the advice stack (facilitator first,
#! then agent — agent's is verified first since it's on top).
#!
#! Reclaim path (at or after expiry): requires only agent_sig over a reclaim
#! message. Creates P2ID to user for full remaining balance. No facilitator
#! signature needed — this is the user's safety valve.
#!
#! Note storage (11 items at STORAGE_PTR):
#!   [0-3]  agent_pubkey_commitment (Word)
#!   [4-7]  facilitator_pubkey_commitment (Word)
#!   [8]    user_account_id_suffix
#!   [9]    user_account_id_prefix
#!   [10]   expiry_block_height
#!
#! Note args:
#!   Consume: [merchant_suffix, merchant_prefix, amount, 0]
#!   Reclaim: [0, 0, 0, 0]
#!
#! Advice stack (consume): [facilitator_prepared_sig..., agent_prepared_sig...]
#!   Agent sig is on top (verified first), facilitator sig underneath.
#! Advice stack (reclaim): [agent_prepared_sig...]

use miden::protocol::active_note
use miden::protocol::note
use miden::protocol::output_note
use miden::protocol::tx
use miden::core::sys
use miden::core::crypto::dsa::falcon512_poseidon2
use miden::core::crypto::hashes::poseidon2
use miden::standards::wallets::basic->wallet
use miden::standards::notes::p2id

# ── Memory layout ──

const STORAGE_PTR=100
const AGENT_PK_PTR=100
const FACILITATOR_PK_PTR=104
const USER_SUFFIX_PTR=108
const USER_PREFIX_PTR=109
const EXPIRY_BLOCK_PTR=110

const MERCHANT_SUFFIX=8
const MERCHANT_PREFIX=9
const DEBIT_AMOUNT=10

const ASSET_KEY_PTR=12
const ASSET_VALUE_PTR=16

# ── Entry point ──

@note_script
pub proc main
    mem_store.MERCHANT_SUFFIX
    mem_store.MERCHANT_PREFIX
    mem_store.DEBIT_AMOUNT
    drop

    push.STORAGE_PTR exec.active_note::get_storage
    # => [num_items, dest_ptr]
    drop drop
    # Skip count check for now — focus on dual-sig verification

    # Block height check
    exec.tx::get_block_number
    mem_load.EXPIRY_BLOCK_PTR
    swap gt

    if.true
        exec.consume_path
    else
        exec.reclaim_path
    end

    exec.sys::truncate_stack
end

# ── Consume path ──
#! Requires two Falcon signatures on the advice stack:
#!   Top:    agent's prepared signature (verified first)
#!   Below:  facilitator's prepared signature (verified second)

proc consume_path
    # ── 1. Compute MESSAGE ──
    push.0 mem_load.DEBIT_AMOUNT mem_load.MERCHANT_PREFIX mem_load.MERCHANT_SUFFIX
    exec.active_note::get_serial_number
    exec.poseidon2::merge
    # => [MESSAGE]

    # ── 2. Verify AGENT signature (from advice stack) ──
    padw push.AGENT_PK_PTR mem_loadw_le
    # => [AGENT_PK, MESSAGE]
    exec.falcon512_poseidon2::verify
    # => []

    # ── 3. Recompute MESSAGE ──
    push.0 mem_load.DEBIT_AMOUNT mem_load.MERCHANT_PREFIX mem_load.MERCHANT_SUFFIX
    exec.active_note::get_serial_number
    exec.poseidon2::merge
    # => [MESSAGE]

    # ── 4. Verify FACILITATOR signature (from advice map) ──
    padw push.FACILITATOR_PK_PTR mem_loadw_le
    # => [FACILITATOR_PK, MESSAGE]

    # Look up facilitator sig: key = merge(FACILITATOR_PK, MESSAGE)
    dupw.1 dupw.1
    exec.poseidon2::merge
    # => [SIG_KEY, FACILITATOR_PK, MESSAGE]
    adv.push_mapval
    # => [SIG_KEY, FACILITATOR_PK, MESSAGE]
    # AS => [FACILITATOR_SIG]
    dropw
    # => [FACILITATOR_PK, MESSAGE]

    exec.falcon512_poseidon2::verify
    # => []

    # ── 5. Add assets to vault ──
    exec.wallet::add_assets_to_account
    push.ASSET_KEY_PTR exec.active_note::get_assets drop drop

    # ── 6. Create P2ID to merchant ──
    exec.active_note::get_serial_number
    swap.3 push.1 add swap.3
    push.1 push.0
    mem_load.MERCHANT_PREFIX mem_load.MERCHANT_SUFFIX
    exec.p2id::new

    push.0.0.0 mem_load.DEBIT_AMOUNT
    padw push.ASSET_KEY_PTR mem_loadw_le
    call.wallet::move_asset_to_note
    dropw dropw dropw dropw

    # ── 7. Create remainder AgentDebitNote ──
    exec.active_note::get_script_root
    exec.active_note::get_serial_number
    push.1 add
    push.11 push.STORAGE_PTR
    exec.note::build_recipient
    push.1 push.0
    exec.output_note::create

    push.ASSET_VALUE_PTR mem_load mem_load.DEBIT_AMOUNT sub
    push.0.0.0 movup.3
    padw push.ASSET_KEY_PTR mem_loadw_le
    call.wallet::move_asset_to_note
    dropw dropw dropw dropw
end

# ── Reclaim path ──
#! After expiry, only agent_sig required (no facilitator co-sign).
#! Creates P2ID to user for full balance.

proc reclaim_path
    # Compute reclaim MESSAGE
    push.0.0
    mem_load.USER_PREFIX_PTR mem_load.USER_SUFFIX_PTR
    exec.active_note::get_serial_number
    exec.poseidon2::merge
    # => [MESSAGE]

    # Verify agent sig only (no facilitator needed after expiry)
    padw push.AGENT_PK_PTR mem_loadw_le
    exec.falcon512_poseidon2::verify

    # Add assets + create P2ID to user
    exec.wallet::add_assets_to_account
    push.ASSET_KEY_PTR exec.active_note::get_assets drop drop

    exec.active_note::get_serial_number
    swap.3 push.1 add swap.3
    push.1 push.0
    mem_load.USER_PREFIX_PTR mem_load.USER_SUFFIX_PTR
    exec.p2id::new

    padw push.ASSET_VALUE_PTR mem_loadw_le
    padw push.ASSET_KEY_PTR mem_loadw_le
    call.wallet::move_asset_to_note
    dropw dropw dropw dropw
end

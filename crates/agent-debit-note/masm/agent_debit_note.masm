#! AgentDebitNote — batch-settlement spec.
#!
#! Consume path (before reclaim_block_height): requires agent signature over
#! the debit message. Creates P2ID(cumulativeAmount) to committed merchant
#! + remainder AgentDebitNote with leftover balance.
#!
#! Reclaim path (at or after reclaim_block_height): requires agent signature
#! over a reclaim message. Creates P2ID to user for full remaining balance.
#!
#! Note storage (9 items at STORAGE_PTR):
#!   [0-3]  user_pub_key_commitment (Word)
#!   [4]    merchant_account_id_suffix
#!   [5]    merchant_account_id_prefix
#!   [6]    user_account_id_suffix
#!   [7]    user_account_id_prefix
#!   [8]    reclaim_block_height
#!
#! Note args:
#!   Consume: [cumulativeAmount, 0, 0, 0]
#!   Reclaim: [0, 0, 0, 0]
#!
#! Advice map (consume): key = merge(USER_PK, MESSAGE) → [prepared_sig...]

use miden::protocol::active_note
use miden::protocol::note
use miden::protocol::output_note
use miden::protocol::tx
use miden::core::sys
use miden::core::crypto::dsa::falcon512_poseidon2
use miden::core::crypto::hashes::poseidon2
use miden::standards::wallets::basic->wallet
use miden::standards::notes::p2id

# ── Memory layout ──

const STORAGE_PTR=100
const USER_PK_PTR=100
const MERCHANT_SUFFIX_PTR=104
const MERCHANT_PREFIX_PTR=105
const USER_SUFFIX_PTR=106
const USER_PREFIX_PTR=107
const RECLAIM_BLOCK_PTR=108

const CUMULATIVE_AMOUNT=8

const ASSET_KEY_PTR=12
const ASSET_VALUE_PTR=16

# ── Entry point ──

@note_script
pub proc main
    # note_args: [cumulativeAmount, 0, 0, 0]
    # Stack on entry: [arg3, arg2, arg1, arg0, ...]
    # arg0 = cumulativeAmount (top after 3 drops)
    mem_store.CUMULATIVE_AMOUNT
    drop drop drop

    push.STORAGE_PTR exec.active_note::get_storage
    # => [num_items, dest_ptr]
    drop drop

    # Route by block height
    # block_number > reclaim_block → consume (not expired)
    # block_number <= reclaim_block → reclaim (expired or at expiry)
    exec.tx::get_block_number
    mem_load.RECLAIM_BLOCK_PTR
    swap gt

    if.true
        exec.consume_path
    else
        exec.reclaim_path
    end

    exec.sys::truncate_stack
end

# ── Consume path ──
#! Single agent signature over debit message.
#! Merchant loaded from committed storage (not note_args).

proc consume_path
    # ── 1. Compute MESSAGE = merge(serial_num, [merchant_suffix, merchant_prefix, cumulativeAmount, 0]) ──
    push.0 mem_load.CUMULATIVE_AMOUNT mem_load.MERCHANT_PREFIX_PTR mem_load.MERCHANT_SUFFIX_PTR
    exec.active_note::get_serial_number
    exec.poseidon2::merge
    # => [MESSAGE]

    # ── 2. Verify agent signature (advice map lookup) ──
    padw push.USER_PK_PTR mem_loadw_le
    # => [USER_PK, MESSAGE]

    # Compute map key = merge(USER_PK, MESSAGE)
    dupw.1 dupw.1
    # => [USER_PK, MESSAGE, USER_PK, MESSAGE]
    exec.poseidon2::merge
    # => [SIG_KEY, USER_PK, MESSAGE]

    # Check if sig is in advice map
    adv.has_mapkey
    # => [SIG_KEY, USER_PK, MESSAGE]
    adv_push.1
    # => [has_sig, SIG_KEY, USER_PK, MESSAGE]

    if.true
        # Sig in map — push to advice stack
        adv.push_mapval
        # => [SIG_KEY, USER_PK, MESSAGE]
        dropw
        # => [USER_PK, MESSAGE]
    else
        # Sig already on advice stack
        dropw
        # => [USER_PK, MESSAGE]
    end

    exec.falcon512_poseidon2::verify
    # => []

    # ── 3. Add assets to vault ──
    exec.wallet::add_assets_to_account
    push.ASSET_KEY_PTR exec.active_note::get_assets drop drop

    # ── 4. Create P2ID(cumulativeAmount) to committed merchant ──
    exec.active_note::get_serial_number
    swap.3 push.1 add swap.3
    push.1 push.0
    mem_load.MERCHANT_PREFIX_PTR mem_load.MERCHANT_SUFFIX_PTR
    exec.p2id::new

    push.0.0.0 mem_load.CUMULATIVE_AMOUNT
    padw push.ASSET_KEY_PTR mem_loadw_le
    call.wallet::move_asset_to_note
    dropw dropw dropw dropw

    # ── 5. Create remainder AgentDebitNote ──
    exec.active_note::get_script_root
    exec.active_note::get_serial_number
    push.1 add
    push.9 push.STORAGE_PTR
    exec.note::build_recipient
    push.1 push.0
    exec.output_note::create

    push.ASSET_VALUE_PTR mem_load mem_load.CUMULATIVE_AMOUNT sub
    push.0.0.0 movup.3
    padw push.ASSET_KEY_PTR mem_loadw_le
    call.wallet::move_asset_to_note
    dropw dropw dropw dropw
end

# ── Reclaim path ──
#! After reclaim_block_height, agent signature required over reclaim message.
#! Creates P2ID to user for full balance.

proc reclaim_path
    # Compute reclaim MESSAGE = merge(serial_num, [user_suffix, user_prefix, 0, 0])
    push.0.0
    mem_load.USER_PREFIX_PTR mem_load.USER_SUFFIX_PTR
    exec.active_note::get_serial_number
    exec.poseidon2::merge
    # => [MESSAGE]

    # Verify agent sig only
    padw push.USER_PK_PTR mem_loadw_le
    exec.falcon512_poseidon2::verify

    # Add assets + create P2ID to user
    exec.wallet::add_assets_to_account
    push.ASSET_KEY_PTR exec.active_note::get_assets drop drop

    exec.active_note::get_serial_number
    swap.3 push.1 add swap.3
    push.1 push.0
    mem_load.USER_PREFIX_PTR mem_load.USER_SUFFIX_PTR
    exec.p2id::new

    padw push.ASSET_VALUE_PTR mem_loadw_le
    padw push.ASSET_KEY_PTR mem_loadw_le
    call.wallet::move_asset_to_note
    dropw dropw dropw dropw
end
